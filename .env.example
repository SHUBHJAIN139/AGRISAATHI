# =============================================================================
# AgriSaathi — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in real values for your deployment.
# ⚠️  NEVER commit `.env` — only `.env.example` is tracked in git.
# =============================================================================

# --- LLM Configuration ---
# Set MOCK_LLM=true for offline development (uses deterministic mock responses).
# Set MOCK_LLM=false + provide GOOGLE_API_KEY for real Gemini inference.
MOCK_LLM=true
GOOGLE_API_KEY=your-gemini-api-key-here
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# --- Model Selection ---
# Used by CropDoctor (vision) and FarmerConcierge (orchestration).
LLM_MODEL=gemini-2.0-flash
VISION_MODEL=gemini-2.0-flash

# --- API Gateway ---
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- JWT Auth ---
# In production, use Firebase Auth public keys. For local dev, this shared
# secret signs/verifies mock JWTs.
JWT_SECRET=change-me-in-production-use-secret-manager
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# --- Session Storage ---
# "sqlite" for local dev, "firestore" for production.
SESSION_BACKEND=sqlite
SQLITE_DB_PATH=./data/sessions.db

# --- Firestore (production only) ---
FIRESTORE_COLLECTION=agri_saathi_sessions

# --- MCP Server Transports ---
# "stdio" for local (ADK launches as subprocess), "sse" for remote.
MCP_TRANSPORT=stdio
WEATHER_MCP_URL=http://localhost:8081/mcp
MANDI_MCP_URL=http://localhost:8082/mcp
SCHEMES_MCP_URL=http://localhost:8083/mcp

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Audit Logging ---
AUDIT_LOG_PATH=./data/audit.log

# --- Frontend ---
VITE_API_URL=http://localhost:8080
